<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LMTrainingDataStudio2.ViewModels"
        xmlns:views="using:LMTrainingDataStudio2.Views"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="LMTrainingDataStudio2.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LLM Training Data Studio"
        MinWidth="1280" MinHeight="720"
        Width="1440" Height="900"
        Background="{StaticResource CanvasBackgroundBrush}">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0" />
        </Style>
    </Window.Styles>

    <Grid>
    <DockPanel>
        <!-- Recipe Header (48px) -->
        <Border DockPanel.Dock="Top" Height="48"
                Background="{StaticResource HeaderBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <!-- App Icon / Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="⚗️" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Text="{Binding RecipeName, Mode=TwoWay}"
                             FontSize="14" FontWeight="SemiBold"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#FFFFFF"
                             VerticalAlignment="Center"
                             MinWidth="200" />
                </StackPanel>

                <!-- Spacer -->
                <Border Grid.Column="1" />

                <!-- Editor / Executions Toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="2" Margin="0,0,12,0">
                    <Button Content="Editor" Command="{Binding SwitchToEditorCommand}"
                            Classes.accent="{Binding IsEditorView}"
                            Padding="12,6" FontSize="12" />
                    <Button Content="Executions" Command="{Binding SwitchToExecutionsCommand}"
                            Classes.accent="{Binding !IsEditorView}"
                            Padding="12,6" FontSize="12" />
                </StackPanel>

                <!-- Settings -->
                <Button Grid.Column="3" Content="⚙" FontSize="16"
                    Command="{Binding OpenSettingsCommand}"
                        Background="Transparent" Foreground="#AAAAAA"
                        VerticalAlignment="Center" Margin="0,0,12,0"
                        Padding="8,4" />
            </Grid>
        </Border>

        <!-- Status Bar (28px) -->
        <Border DockPanel.Dock="Bottom" Height="28"
                Background="{StaticResource StatusBarBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           FontSize="11" VerticalAlignment="Center" Margin="12,0"
                           Foreground="#AAAAAA" />
                <TextBlock Grid.Column="1"
                           Text="{Binding TotalLines, StringFormat='Lines: {0}'}"
                           FontSize="11" VerticalAlignment="Center" Margin="12,0"
                           Foreground="#888888" />
                <ProgressBar Grid.Column="2" Value="{Binding Progress}"
                             Minimum="0" Maximum="1"
                             Height="3" VerticalAlignment="Center"
                             Margin="12,0"
                             IsVisible="{Binding IsRunning}" />
                <TextBlock Grid.Column="3" Text="{Binding CurrentFilePath}"
                           FontSize="11" VerticalAlignment="Center" Margin="12,0"
                           Foreground="#888888" MaxWidth="300"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="4" Text="{Binding MemoryUsage}"
                           FontSize="11" VerticalAlignment="Center" Margin="12,0"
                           Foreground="#888888" />
                <TextBlock Grid.Column="5" Text="{Binding CanvasZoomText}"
                           FontSize="11" VerticalAlignment="Center" Margin="12,0"
                           Foreground="#888888" />
            </Grid>
        </Border>

        <!-- Main Content: Three-Column Layout -->
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Block Sheet Panel (200px) -->
            <Grid Grid.Column="0">
                <!-- Collapsed state: show expand button -->
                <Border Width="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,1,0"
                        IsVisible="{Binding !IsBlockSheetVisible}">
                    <Button Content="▶" FontSize="10"
                            Command="{Binding ToggleBlockSheetCommand}"
                            Background="Transparent" Foreground="#888888"
                            Padding="4,2" VerticalAlignment="Top" Margin="0,8,0,0"
                            ToolTip.Tip="Show Blocks" />
                </Border>

                <!-- Expanded state: full panel -->
                <Border Width="200"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,1,0"
                        IsVisible="{Binding IsBlockSheetVisible}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Height="36"
                                Background="{StaticResource HeaderBackgroundBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Blocks" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="12,0"
                                           Foreground="#CCCCCC" />
                                <Button Grid.Column="1" Content="◀" FontSize="10"
                                        Command="{Binding ToggleBlockSheetCommand}"
                                        Background="Transparent" Foreground="#888888"
                                        Padding="6,2" Margin="0,0,4,0"
                                        ToolTip.Tip="Hide Blocks" />
                            </Grid>
                        </Border>

                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding BlockTemplates}" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BlockTemplateViewModel">
                                        <Border Margin="0,4" Padding="10,8"
                                                CornerRadius="6"
                                                Background="#2A2A3E"
                                                BorderBrush="#3A3A4E" BorderThickness="1"
                                                Cursor="Hand"
                                                PointerPressed="OnBlockTemplatePointerPressed">
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding IconText}" FontSize="14" />
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#E0E0E0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="10"
                                                           Foreground="#888888" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Left GridSplitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          Background="Transparent"
                          IsVisible="{Binding IsBlockSheetVisible}" />

            <!-- Canvas Area (Center) -->
            <Grid Grid.Column="2">
                <!-- Canvas Background -->
                <Border Background="{StaticResource CanvasBackgroundBrush}">
                    <views:RecipeCanvasView DataContext="{Binding}" />
                </Border>

                <!-- Floating Controls (Run / Validate) - Bottom Right -->
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Orientation="Horizontal" Spacing="8"
                            Margin="0,0,16,16">
                    <Button Content="✓ Validate" Command="{Binding ValidateRecipeCommand}"
                            Padding="14,8" FontSize="12"
                            Background="#2D5A2D" Foreground="#FFFFFF"
                            CornerRadius="6"
                            IsEnabled="{Binding !IsRunning}" />
                    <Button Content="▶ Run" Command="{Binding RunRecipeCommand}"
                            Padding="14,8" FontSize="12"
                            Background="#4A90D9" Foreground="#FFFFFF"
                            CornerRadius="6"
                            IsEnabled="{Binding !IsRunning}" />
                </StackPanel>

            </Grid>

            <!-- Right GridSplitter -->
            <GridSplitter Grid.Column="3" Width="4"
                          Background="Transparent"
                          IsVisible="{Binding IsPropertyPanelVisible}" />

            <!-- Property Panel (320px) -->
            <Grid Grid.Column="4">
                <!-- Collapsed state: show expand button -->
                <Border Width="24"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1,0,0,0"
                        IsVisible="{Binding !IsPropertyPanelVisible}">
                    <Button Content="◀" FontSize="10"
                            Command="{Binding TogglePropertyPanelCommand}"
                            Background="Transparent" Foreground="#888888"
                            Padding="4,2" VerticalAlignment="Top" Margin="0,8,0,0"
                            ToolTip.Tip="Show Properties" />
                </Border>

                <!-- Expanded state: full panel -->
                <Border Width="320"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1,0,0,0"
                        IsVisible="{Binding IsPropertyPanelVisible}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Height="36"
                                Background="{StaticResource HeaderBackgroundBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Button Grid.Column="0" Content="▶" FontSize="10"
                                        Command="{Binding TogglePropertyPanelCommand}"
                                        Background="Transparent" Foreground="#888888"
                                        Padding="6,2" Margin="4,0,0,0"
                                        ToolTip.Tip="Hide Properties" />
                                <TextBlock Grid.Column="1" Text="Properties" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="8,0"
                                           Foreground="#CCCCCC" />
                            </Grid>
                        </Border>

                        <ScrollViewer>
                            <views:PropertyPanelView DataContext="{Binding}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>

    <!-- Settings overlay -->
    <Border IsVisible="{Binding IsSettingsVisible}"
            Background="#99000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ZIndex="1000">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Width="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#252538"
                    BorderBrush="#4A90D9"
                    BorderThickness="1"
                    CornerRadius="12"
                    BoxShadow="0 18 42 0 #66000000">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Height="56"
                            Background="#2D2D44"
                            CornerRadius="12,12,0,0"
                            BorderBrush="#3A3A4E"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto" Margin="18,0,12,0">
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                <TextBlock Text="Cache, theme and canvas interaction preferences" FontSize="11" Foreground="#9A9AAD" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding CloseSettingsCommand}"
                                    Background="Transparent"
                                    Foreground="#AAAAAA"
                                    FontSize="14"
                                    Padding="8,4"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Margin="22" Spacing="18">
                        <Border Background="#1E1E2E" BorderBrush="#3A3A4E" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Index Cache" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                <TextBlock Text="SQLite cache for large JSONL line offsets. Keep this on a fast local disk." FontSize="11" Foreground="#9A9AAD" TextWrapping="Wrap" />

                                <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Max cache size (MB)" VerticalAlignment="Center" Foreground="#CCCCCC" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MaxCacheSizeMb, Mode=TwoWay}" Watermark="512" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Cache directory" VerticalAlignment="Center" Foreground="#CCCCCC" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CacheDirectory, Mode=TwoWay}" Watermark="tmp/index-cache" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Current cache size" VerticalAlignment="Center" Foreground="#CCCCCC" />
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding CacheSizeText}" VerticalAlignment="Center" Foreground="#AAAAAA" />
                                        <Button Content="Clean Cache"
                                                Command="{Binding CleanIndexCacheCommand}"
                                                Padding="10,5"
                                                Background="#3A3A4E"
                                                Foreground="#FFFFFF" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E2E" BorderBrush="#3A3A4E" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Canvas" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="12">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Enable grid snap" VerticalAlignment="Center" Foreground="#CCCCCC" />
                                    <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding EnableGridSnap, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Grid snap size (px)" VerticalAlignment="Center" Foreground="#CCCCCC" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding GridSnapSize, Mode=TwoWay}" Watermark="16" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E2E" BorderBrush="#3A3A4E" BorderThickness="1" CornerRadius="8" Padding="16">
                            <Grid ColumnDefinitions="180,*" ColumnSpacing="12">
                                <TextBlock Grid.Column="0" Text="Dark theme" VerticalAlignment="Center" Foreground="#CCCCCC" />
                                <CheckBox Grid.Column="1" IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="Cancel"
                                    Command="{Binding CloseSettingsCommand}"
                                    Padding="14,7"
                                    Background="#3A3A4E"
                                    Foreground="#FFFFFF" />
                            <Button Content="Apply"
                                    Command="{Binding ApplySettingsCommand}"
                                    Padding="16,7"
                                    Background="#4A90D9"
                                    Foreground="#FFFFFF" />
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
    </Grid>
</Window>
